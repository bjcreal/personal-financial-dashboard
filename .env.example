# ─────────────────────────────────────────────────────────────────────────────
# AWS Configuration
# ─────────────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1

# Set by SAM / CloudFormation after deploy — copy from stack Outputs
AWS_COGNITO_USER_POOL_ID=us-east-1_xxxxxxxxx
AWS_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────────────────────────────────────
# AWS Secrets Manager (backend reads these automatically)
# Store these as JSON in Secrets Manager before deploying:
#
#   aws secretsmanager create-secret \
#     --name financial-dashboard/plaid \
#     --secret-string '{"client_id":"...","secret":"..."}'
#
#   aws secretsmanager create-secret \
#     --name financial-dashboard/coinbase \
#     --secret-string '{"client_id":"...","client_secret":"..."}'
# ─────────────────────────────────────────────────────────────────────────────

# ─────────────────────────────────────────────────────────────────────────────
# Local backend development only (not used in Lambda)
# Copy to backend/.env for local uvicorn dev server
# ─────────────────────────────────────────────────────────────────────────────
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

COINBASE_CLIENT_ID=
COINBASE_CLIENT_SECRET=
COINBASE_REDIRECT_URI=http://localhost:8000/api/crypto/oauth/callback

# Override table names for local DynamoDB (e.g. dynamodb-local)
USERS_TABLE=financial-dashboard-users-dev
PLAID_ITEMS_TABLE=financial-dashboard-plaid-items-dev
ACCOUNTS_TABLE=financial-dashboard-accounts-dev
BALANCES_TABLE=financial-dashboard-balances-dev
TRANSACTIONS_TABLE=financial-dashboard-transactions-dev

# ─────────────────────────────────────────────────────────────────────────────
# Frontend (Next.js / AWS Amplify)
# Copy to frontend/.env.local for local Next.js dev
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://xxxxxxxxxx.execute-api.us-east-1.amazonaws.com/prod
NEXT_PUBLIC_COGNITO_USER_POOL_ID=us-east-1_xxxxxxxxx
NEXT_PUBLIC_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
